# =============================================================================
# valheim.env - Configuration for the Valheim Dedicated Server
# Copy this file to valheim.env and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Server identity
# -----------------------------------------------------------------------------

# Display name shown in the server browser
SERVER_NAME=My Valheim Server

# World save file name (no extension)
WORLD_NAME=Dedicated

# Server password - MUST be at least 5 characters or the server will not start
SERVER_PASS=changeme

# List the server publicly on the Steam server browser (true/false)
SERVER_PUBLIC=false

# -----------------------------------------------------------------------------
# Timezone (used by cron schedules inside the container)
# Must be a valid tz database entry, e.g. Europe/Paris, America/New_York
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# -----------------------------------------------------------------------------
TZ=Etc/UTC

# -----------------------------------------------------------------------------
# Automatic scheduling (cron expressions, 5-field format)
# Leave empty to disable a schedule.
#
# Examples:
#   "0 4 * * *"    -> Daily at 04:00
#   "0 */6 * * *"  -> Every 6 hours
#   "*/30 * * * *" -> Every 30 minutes
# -----------------------------------------------------------------------------

# Auto-update the server image
UPDATE_CRON=

# Auto-restart the server container
RESTART_CRON=

# Auto-backup worlds
BACKUPS_CRON=

# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------

# Enable crossplay (Steam + Xbox / Game Pass players)
CROSSPLAY=false

# Enable Supervisor HTTP interface on port 9001 (true/false)
SUPERVISOR_HTTP=false

# Password for the Supervisor web interface
SUPERVISOR_HTTP_PASS=

# Enable BepInEx mod loader (true/false)
# Cannot be enabled at the same time as VALHEIM_PLUS
BEPINEX=false

# Enable Valheim Plus (true/false)
# Cannot be enabled at the same time as BEPINEX
VALHEIM_PLUS=false

# -----------------------------------------------------------------------------
# Windows -> Linux world sync (odin sync-worlds)
# Required only if you use the sync-worlds feature.
# See: odin sync-worlds --help-guide
# -----------------------------------------------------------------------------

# Windows account name (e.g. the folder under C:\Users\)
WIN_USER=

# IP address or hostname of your Windows machine (Tailscale IP recommended)
WIN_HOST=

# SSH username on the Windows machine
WIN_SSH_USER=

# SSH port on the Windows machine (default: 22)
WIN_SSH_PORT=22

# Absolute path to your SSH private key on this Linux server
# Example: /home/youruser/.ssh/id_ed25519
WIN_SSH_KEY=

# -----------------------------------------------------------------------------
# Container user mapping
# Match these to the UID/GID of the user that owns ./data and ./config
# Run: id -u && id -g   to find your current UID/GID
# -----------------------------------------------------------------------------
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# Patch DLL auto-restore
# Set APPLY_DLL_PATCH=true to apply patches/assembly_valheim.dll before each
# game server start. The hook below always runs; the script exits immediately
# when APPLY_DLL_PATCH is false, so it is safe to leave the hook set at all times.
#
# Requires: ./patches/assembly_valheim.dll  (your patched DLL)
#           ./scripts/apply-patch.sh        (mounted read-only at /scripts)
# -----------------------------------------------------------------------------
APPLY_DLL_PATCH=false

# Fixed hook - do not remove or change this line.
PRE_SERVER_RUN_HOOK=/scripts/apply-patch.sh
